{
  "name": "tools-github-issues-resolver",
  "version": "1.0.0",
  "description": "CLI to read a git remote and fetch open GitHub issues.",
  "type": "module",
  "bin": {
    "github-issues-resolver": "./src/cli/cli.js",
    "issues-relay-server": "./src/server/server.js"
  },
  "files": [
    "src",
    "build",
    "AGENT.md"
  ],
  "scripts": {
    "build:windows-exe": "node ./build/cli/build-windows-exe.mjs",
    "build:windows-server-exe": "node ./build/server/build-windows-exe.mjs",
    "start": "node ./src/cli/cli.js",
    "test": "node --check ./src/cli/cli.js && node --check ./src/server/server.js && node --check ./src/shared/repository.js && node --check ./build/cli/build-windows-exe.mjs && node --check ./build/server/build-windows-exe.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "github",
    "issues",
    "git",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "postject": "^1.0.0-alpha.6"
  }
}
